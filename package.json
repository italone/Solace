{
  "name": "@italone/solace",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs/*.md",
    "readme.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite examples/basic-counter",
    "dev:todo": "vite examples/todo-app",
    "dev:large": "vite examples/large-list",
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "typecheck:jsxdev": "tsc --noEmit -p tsconfig.jsxdev.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:package": "pnpm build && vitest run --config vitest.package.config.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "node scripts/run-benchmark.mjs",
    "benchmark:history": "node scripts/summarize-benchmark-history.mjs",
    "build:benchmark:browser": "vite build examples/performance-benchmark",
    "benchmark:browser": "playwright test --config playwright.benchmark.config.ts",
    "package:smoke": "node scripts/package-consumer-smoke.mjs",
    "changeset": "changeset",
    "release:readiness": "node scripts/release-readiness-check.mjs",
    "release:version": "changeset version",
    "release:check": "pnpm quality && pnpm test:coverage && pnpm package:smoke && pnpm benchmark && pnpm benchmark:browser && pnpm test:e2e",
    "release:publish": "pnpm release:check && changeset publish",
    "quality": "pnpm format:check && pnpm typecheck && pnpm typecheck:jsxdev && pnpm lint && pnpm test && pnpm test:package"
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tinybench": "^6.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
